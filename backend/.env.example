# RECOCO Backend Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key (Required)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional fallback keys (used when quota/rate-limit is hit)
# GEMINI_API_KEY_SUB=your_backup_gemini_api_key_here
# GEMINI_API_KEY_INSU=your_second_backup_gemini_api_key_here
# Optional: comma-separated override list (highest priority if set)
# GEMINI_API_KEYS=key1,key2,key3

# Optional: Custom model settings
# GEMINI_STORY_MODEL=gemini-2.5-flash
# GEMINI_SUGGESTIONS_MODEL=gemini-2.5-flash

# Optional: CORS origins (comma-separated)
# CORS_ORIGINS=["http://localhost:5173","https://your-frontend.com"]
