# ============================================
# RECOCO Environment Variables Example
# Copy to .env and fill with real values.
# Do not commit the real .env file.
# Frontend reads root .env.
# Backend reads process env, or backend/.env when run from backend/.
# ============================================

# Frontend / Vite
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"
VITE_API_BASE_URL="http://127.0.0.1:8000"
VITE_BACKEND_PORT=8000

# Backend / Gemini / Geocoding
GOOGLE_CLOUD_API_KEY="your_google_cloud_api_key"
GEMINI_API_KEY="your_primary_gemini_api_key"
GEMINI_API_KEY_SUB=""
GEMINI_API_KEY_INSU=""
GEMINI_API_KEYS=""

# Backend / Supabase admin
SERVICE_ROLE_KEY="your_supabase_service_role_key"

# Optional backend port override
PORT=8000
